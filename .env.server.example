POSTGRES_DB=phlowbooks
POSTGRES_USER=phlowbooks
POSTGRES_PASSWORD=replace-with-a-long-random-password

APP_ENV=production
SECRET_KEY=replace-with-a-random-32-byte-hex
API_KEY=replace-with-a-random-string
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

MAX_FILE_SIZE_MB=20
MAX_FILES_PER_UPLOAD=50
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=replace-with-app-password
SMTP_FROM=you@gmail.com
SMTP_USE_TLS=true

FRONTEND_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN
CORS_ORIGINS=http://YOUR_SERVER_IP_OR_DOMAIN

PAYMONGO_SECRET_KEY=sk_...
PAYMONGO_WEBHOOK_SECRET=whsec_...

HTTP_PORT=80
